{
  "name": "flyingo-backend",
  "version": "1.0.0",
  "description": "Backend for Flyingo Travel Agency",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "mocha src/tests/**/*.test.js --exit",
    "lint": "eslint src/**/*.js"
  },
  "husky": {
